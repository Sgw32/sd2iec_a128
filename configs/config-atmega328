# This may not look like it, but it's a -*- makefile -*-
#
# sd2iec - SD/MMC to Commodore serial bus interface/controller
#
# This file is included in the main sd2iec Makefile and also parsed
# into autoconf.h.

CONFIG_ARCH=avr
CONFIG_MCU=atmega328p
CONFIG_LINKER_RELAX=y
CONFIG_MCU_FREQ=16000000
CONFIG_BOOTLOADER=n
CONFIG_UART_DEBUG=n
CONFIG_UART_BAUDRATE=38400
CONFIG_UART_BUF_SHIFT=4
CONFIG_DEADLOCK_ME_HARDER=n
CONFIG_COMMAND_CHANNEL_DUMP=n
CONFIG_LOADER_TURBODISK=n
CONFIG_LOADER_FC3=y
CONFIG_LOADER_DREAMLOAD=n
CONFIG_LOADER_ULOAD3=n
CONFIG_LOADER_GIJOE=n
CONFIG_LOADER_EPYXCART=n
CONFIG_LOADER_GEOS=y
CONFIG_LOADER_WHEELS=n
CONFIG_LOADER_NIPPON=n
CONFIG_LOADER_AR6=n
CONFIG_LOADER_ELOAD1=n
CONFIG_HARDWARE_VARIANT=41
CONFIG_HARDWARE_NAME=atmega328
CONFIG_SD_AUTO_RETRIES=10
CONFIG_SD_DATACRC=y
CONFIG_ERROR_BUFFER_SIZE=48
CONFIG_COMMAND_BUFFER_SIZE=80
CONFIG_BUFFER_COUNT=3
CONFIG_MAX_PARTITIONS=1
CONFIG_RTC_SOFTWARE=y
CONFIG_REMOTE_DISPLAY=n
CONFIG_DISPLAY_BUFFER_SIZE=40
CONFIG_HAVE_IEC=y
CONFIG_M2I=n
CONFIG_HAVE_EEPROMFS=n
CONFIG_LOADER_MMZAK=n
CONFIG_LOADER_N0SDOS=n
CONFIG_LOADER_SAMSJOURNEY=n
